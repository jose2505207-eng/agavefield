APP_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agave_copilot

# Public base URL used to build image links served from /media (local storage).
# When running the API in Docker, the dashboard reaches it via the service name.
PUBLIC_BASE_URL=http://localhost:8000

# CORS allowed origins: "*" for any (dev), or a comma-separated list in prod, e.g.
#   CORS_ALLOW_ORIGINS=https://dashboard.example.com,https://app.example.com
CORS_ALLOW_ORIGINS=*

# --- Telegram (MVP intake) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Set to true on serverless hosts (Vercel) so the webhook processes the photo
# inline instead of in a background task that can be killed after the response.
TELEGRAM_WEBHOOK_SYNC=false

# --- WhatsApp Cloud API (optional; leave blank to disable) ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_DEFAULT_ESCALATION_RECIPIENTS=

# --- Vision model ---
# openai_compatible -> any OpenAI-compatible multimodal endpoint.
# Leave VISION_API_KEY blank to run the offline stub analyzer (no diagnosis).
VISION_PROVIDER=openai_compatible
VISION_API_KEY=
VISION_BASE_URL=https://api.openai.com/v1
VISION_MODEL=gpt-4o-mini

# MVP is a human-centered record system: NO LLM/CV runs on photo upload.
# The app is fully usable WITHOUT any LLM API key. Keep this false in production;
# only enable for a future AI-assisted version once enough human history exists.
ENABLE_AI_IMAGE_ANALYSIS=false

# --- Storage ---
# local -> ./storage served at /media. s3 -> any S3-compatible endpoint.
STORAGE_PROVIDER=local
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_ENDPOINT=
# Supabase Storage (S3): region + public object URL base, e.g.
#   STORAGE_REGION=us-east-1
#   STORAGE_PUBLIC_BASE=https://<project-ref>.supabase.co/storage/v1/object/public
STORAGE_REGION=
STORAGE_PUBLIC_BASE=

# --- Operations / traceability layer ---
# Signs admin login session tokens (HMAC). MUST be a strong random value in
# production (prod refuses to boot otherwise). Rotating it logs everyone out.
# Work-order link tokens use keyless sha256 and are NOT affected by rotation.
SECRET_KEY=change-me-in-production
APP_BASE_URL=http://localhost:8000

# Role-based access for the ops admin endpoints (X-API-Key header).
# Leave ALL blank for open dev mode; set in production to enforce RBAC.
ADMIN_API_KEY=
AGRONOMIST_API_KEY=
REVIEWER_API_KEY=
# The dashboard sends this as X-API-Key (use an admin/agronomist key in prod):
API_KEY=

# --- Web admin login (app_users table; separate from the API-key RBAC above) ---
# The DEMO account (read-only, shows demo data) is always seeded. Override its
# credentials here if desired. Set AUTH_ADMIN_* to seed a real admin login.
# Sessions are signed with SECRET_KEY, so set a strong SECRET_KEY in production.
DEMO_USERNAME=DEMO
DEMO_PASSWORD=DEMO
AUTH_ADMIN_USERNAME=
AUTH_ADMIN_PASSWORD=
SESSION_TTL_HOURS=12

# Email delivery for work-order links. console = local dev (prints to log).
EMAIL_PROVIDER=console            # console | smtp | sendgrid | resend
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Agave Field
SENDGRID_API_KEY=
RESEND_API_KEY=

# --- Weather ---
# auto -> Open-Meteo (no key, falls back to mock on failure).
# mock -> deterministic offline data. openweather -> requires WEATHER_API_KEY.
WEATHER_PROVIDER=auto
WEATHER_API_KEY=

# --- Escalation ---
ESCALATION_COOLDOWN_HOURS=24
