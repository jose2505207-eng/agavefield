APP_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agave_copilot

# Public base URL used to build image links served from /media (local storage).
# When running the API in Docker, the dashboard reaches it via the service name.
PUBLIC_BASE_URL=http://localhost:8000

# --- Telegram (MVP intake) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# --- WhatsApp Cloud API (optional; leave blank to disable) ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_DEFAULT_ESCALATION_RECIPIENTS=

# --- Vision model ---
# openai_compatible -> any OpenAI-compatible multimodal endpoint.
# Leave VISION_API_KEY blank to run the offline stub analyzer (no diagnosis).
VISION_PROVIDER=openai_compatible
VISION_API_KEY=
VISION_BASE_URL=https://api.openai.com/v1
VISION_MODEL=gpt-4o-mini

# --- Storage ---
# local -> ./storage served at /media. s3 -> any S3-compatible endpoint.
STORAGE_PROVIDER=local
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_ENDPOINT=

# --- Weather ---
# auto -> Open-Meteo (no key, falls back to mock on failure).
# mock -> deterministic offline data. openweather -> requires WEATHER_API_KEY.
WEATHER_PROVIDER=auto
WEATHER_API_KEY=

# --- Escalation ---
ESCALATION_COOLDOWN_HOURS=24
