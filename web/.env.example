# Base URL of the Agave Field FastAPI backend the frontend reads from.
NEXT_PUBLIC_API_BASE_URL=https://agavefield-nu.vercel.app

# Server-only API key for RBAC-protected endpoints. Injected into backend calls
# by the same-origin proxy / login route handler — never exposed to the browser.
# Use an admin/agronomist key in production; leave blank in open dev mode.
API_KEY=

# Optional: where the login + proxy route handlers reach the backend server-side.
# Falls back to NEXT_PUBLIC_API_BASE_URL when unset.
API_BASE_URL=

# Session cookie lifetime (hours) for the admin login. Match backend SESSION_TTL_HOURS.
SESSION_TTL_HOURS=12
